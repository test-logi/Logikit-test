<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>The ANT Snake</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <style>
    /* Retro minimal styling */
    :root {
      --bg: #050607;
      --panel: #071017;
      --muted: #9aa;
      --green: #00ff00; /* title green */
      --player1-head: #9aff9a;
      --player1-body: #2ecc40;
      --player2-head: #ffd86b;
      --player2-body: #ffcc00;
      --food: #ff4444;
    }

    body {
      margin: 0;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg);
      color: #cfe;
      font-family: "Courier New", monospace;
    }

    .layout {
      display: grid;
      grid-template-columns: auto 300px;
      gap: 16px;
      align-items: start;
    }

    canvas {
      background: #000;
      image-rendering: pixelated;
      border: 4px solid #222;
      display: block;
    }

    .panel {
      width: 300px;
      background: var(--panel);
      padding: 12px;
      border: 2px solid #222;
      box-sizing: border-box;
      text-align: center;
    }

    .title {
      color: var(--green);
      font-size: 22px;
      font-weight: bold;
      margin-bottom: 10px;
      text-align: center;
    }

    label { display:block; text-align:left; margin-top:8px; color:#cfe; }
    .small { font-size:12px; color:var(--muted); text-align:left; margin-top:6px; }
    input[type="range"], select { width:100%; margin-top:6px; }
    .controls { margin-top:10px; }
    button {
      background:#111; color:#9fd; border:1px solid #333; padding:8px 12px; cursor:pointer;
      font-family:inherit; margin:4px;
    }
    button:disabled { opacity:0.5; cursor:default; }
    .score { text-align:left; margin-top:12px; }
    .overlay {
      position:absolute; left:0; top:0; width:100%; height:100%;
      display:flex; align-items:center; justify-content:center;
      color:#fff; font-size:20px; pointer-events:none;
    }
  </style>
</head>
<body>
  <div class="layout">
    <div style="position:relative;">
      <canvas id="game" width="512" height="512"></canvas>
      <div id="overlay" class="overlay" style="display:none;"></div>
    </div>

    <div class="panel">
      <!-- Title centered, green -->
      <div class="title">The ANT Snake</div>

      <!-- Settings -->
      <label>Speed</label>
      <input id="speed" type="range" min="1" max="10" value="5" />
      <div class="small">1 = slowest, 10 = fastest (applies to players & enemies)</div>

      <label>Enemies</label>
      <select id="enemyCount">
        <option value="0">0 enemies</option>
        <option value="1">1 enemy</option>
        <option value="2">2 enemies</option>
        <option value="3">3 enemies</option>
      </select>

      <label>Mode</label>
      <select id="mode">
        <option value="1">1 Player</option>
        <option value="2">2 Players</option>
      </select>

      <div class="controls">
        <button id="startBtn">Start</button>
        <button id="stopBtn" disabled>Stop</button>
      </div>

      <div class="score">
        <strong>Score P1:</strong> <span id="score1">0</span><br/>
        <strong>Score P2:</strong> <span id="score2">0</span>
      </div>

      <div class="small">
        Controls:<br/>
        Player 1: <strong>W</strong> Up, <strong>A</strong> Left, <strong>S</strong> Down, <strong>D</strong> Right<br/>
        Player 2 (if enabled): Arrow keys
      </div>

      <div class="small">Win when a player's snake covers <strong>65%</strong> of the field.</div>
    </div>
  </div>

  <script>
    /************************************************************************
     * The ANT Snake
     *
     * - Grid-based retro snake with optional enemies and cooperative mode.
     * - Clear separation: Game logic, Rendering, Input handling, Enemy AI.
     * - Clean, commented, minimal design.
     *
     * Rules implemented per user request:
     *  - Title displayed in green, centered above controls.
     *  - Player 1: W/A/S/D (no instant reverse).
     *  - Player 2: Arrow keys (if 2-player mode).
     *  - Enemies: 0-3 selectable. Distinct colors. Move same speed as players.
     *  - Enemies try to eat food and grow like players.
     *  - Aggressive mode: triggered when a player eats >5 in a row and enemies have 0 eats.
     *    Enemies turn gray and target players for 10s or until the triggering player eats 2 more dots.
     *  - Map size doubles for 2-3 enemies.
     *  - Win: a player's snake covers 65% of total cells.
     ************************************************************************/

    /* -------------------------
       UI & Canvas references
       ------------------------- */
    const canvas = document.getElementById('game');
    const ctx = canvas.getContext('2d');
    const startBtn = document.getElementById('startBtn');
    const stopBtn = document.getElementById('stopBtn');
    const speedInput = document.getElementById('speed');
    const enemyCountSelect = document.getElementById('enemyCount');
    const modeSelect = document.getElementById('mode');
    const overlay = document.getElementById('overlay');
    const score1El = document.getElementById('score1');
    const score2El = document.getElementById('score2');

    /* -------------------------
       Constants & configuration
       ------------------------- */
    const STANDARD_COLS = 16;
    const STANDARD_ROWS = 16;
    const COLORS = {
      player1Head: '#9aff9a',
      player1Body: '#2ecc40',
      player2Head: '#ffd86b',
      player2Body: '#ffcc00',
      food: '#ff4444',
      enemyColors: ['#66ccff', '#ff66cc', '#ffcc66'],
      enemyGray: '#888888',
      gridLine: '#0b0b0b'
    };

    // Aggressive mode constants
    const AGGRO_THRESHOLD = 5; // >5 consecutive eats triggers
    const AGGRO_DURATION_MS = 10000; // 10 seconds
    const AGGRO_EXTRA_EATS_TO_END = 2; // player eats 2 more dots ends aggro early

    /* -------------------------
       Dynamic game state
       ------------------------- */
    let GRID_COLS = STANDARD_COLS;
    let GRID_ROWS = STANDARD_ROWS;
    let CELL_SIZE = 32; // will be recalculated

    // Actors: players and enemies stored in arrays
    // Each actor: { id, type: 'player'|'enemy', snake:[{x,y}], dir:{x,y}, nextDir:{x,y}, colorHead, colorBody, alive, eats, consecutiveEats }
    let players = [];   // up to 2 players
    let enemies = [];   // 0-3 enemies
    let food = null;

    // Game control
    let running = false;
    let settingsLocked = false;
    let moveInterval = 200; // ms between moves (based on speed)
    let lastTime = 0;
    let moveTimer = 0;

    // Aggressive mode tracking
    let aggroActive = false;
    let aggroTimer = 0;
    let aggroTriggeringPlayerId = null;
    let aggroPlayerEatsAtStart = 0;

    /* -------------------------
       Utility helpers
       ------------------------- */
    function mod(n, m) { return ((n % m) + m) % m; }
    function randInt(n) { return Math.floor(Math.random() * n); }

    /* -------------------------
       Grid & sizing
       ------------------------- */
    function configureGrid() {
      const enemyCount = parseInt(enemyCountSelect.value, 10);
      if (enemyCount <= 1) {
        GRID_COLS = STANDARD_COLS;
        GRID_ROWS = STANDARD_ROWS;
      } else {
        GRID_COLS = STANDARD_COLS * 2;
        GRID_ROWS = STANDARD_ROWS * 2;
      }
      // adjust canvas size to keep square cells and reasonable pixel size
      const size = Math.min(720, Math.max(320, GRID_COLS * 24));
      canvas.width = size;
      canvas.height = size;
      CELL_SIZE = canvas.width / GRID_COLS;
    }

    /* -------------------------
       Actor creation
       ------------------------- */
    function createPlayer(id, startX, startY, dir, headColor, bodyColor) {
      return {
        id,
        type: 'player',
        snake: [{ x: startX, y: startY }, { x: startX - 1, y: startY }, { x: startX - 2, y: startY }],
        dir: { ...dir },
        nextDir: { ...dir },
        colorHead: headColor,
        colorBody: bodyColor,
        alive: true,
        eats: 0,
        consecutiveEats: 0
      };
    }

    function createEnemy(id, startX, startY, dir, color) {
      return {
        id,
        type: 'enemy',
        snake: [{ x: startX, y: startY }, { x: startX - 1, y: startY }, { x: startX - 2, y: startY }],
        dir: { ...dir },
        nextDir: { ...dir },
        colorHead: color,
        colorBody: shadeColor(color, -20),
        alive: true,
        eats: 0,
        consecutiveEats: 0,
        aggro: false // whether currently gray/aggressive
      };
    }

    // Slightly shade a hex color by adding percent (-255..255)
    function shadeColor(hex, delta) {
      const num = parseInt(hex.slice(1), 16);
      let r = (num >> 16) + delta;
      let g = ((num >> 8) & 0xff) + delta;
      let b = (num & 0xff) + delta;
      r = Math.max(0, Math.min(255, r));
      g = Math.max(0, Math.min(255, g));
      b = Math.max(0, Math.min(255, b));
      return '#' + ((r << 16) | (g << 8) | b).toString(16).padStart(6, '0');
    }

    /* -------------------------
       Initialize / Reset game
       ------------------------- */
    function resetGameState() {
      configureGrid();
      players = [];
      enemies = [];
      food = null;
      aggroActive = false;
      aggroTimer = 0;
      aggroTriggeringPlayerId = null;
      aggroPlayerEatsAtStart = 0;

      // Create players based on mode
      const mode = parseInt(modeSelect.value, 10);
      // Player 1 centered
      const midX = Math.floor(GRID_COLS / 2);
      const midY = Math.floor(GRID_ROWS / 2);
      players.push(createPlayer(1, midX, midY, { x: 1, y: 0 }, COLORS.player1Head, COLORS.player1Body));
      if (mode === 2) {
        // Player 2 slightly below center
        players.push(createPlayer(2, midX, midY + 2, { x: 1, y: 0 }, COLORS.player2Head, COLORS.player2Body));
      }

      // Create enemies based on selection
      const enemyCount = parseInt(enemyCountSelect.value, 10);
      const spawnPositions = generateEnemySpawns(enemyCount);
      for (let i = 0; i < enemyCount; i++) {
        const pos = spawnPositions[i];
        enemies.push(createEnemy(i + 1, pos.x, pos.y, { x: -1, y: 0 }, COLORS.enemyColors[i % COLORS.enemyColors.length]));
      }

      placeFood();
      updateScoreUI();
      overlay.style.display = 'none';
    }

    // Generate spawn positions for enemies (spread out)
    function generateEnemySpawns(count) {
      const positions = [];
      const marginX = Math.max(2, Math.floor(GRID_COLS / 8));
      const marginY = Math.max(2, Math.floor(GRID_ROWS / 8));
      const candidates = [
        { x: marginX, y: marginY },
        { x: GRID_COLS - 1 - marginX, y: marginY },
        { x: marginX, y: GRID_ROWS - 1 - marginY },
        { x: GRID_COLS - 1 - marginX, y: GRID_ROWS - 1 - marginY },
        { x: Math.floor(GRID_COLS / 4), y: Math.floor(GRID_ROWS / 2) },
        { x: Math.floor(3 * GRID_COLS / 4), y: Math.floor(GRID_ROWS / 2) }
      ];
      for (let i = 0; i < count; i++) positions.push(candidates[i % candidates.length]);
      return positions;
    }

    /* -------------------------
       Food placement
       ------------------------- */
    function placeFood() {
      // Place food in a free cell (not on any snake)
      while (true) {
        const fx = randInt(GRID_COLS);
        const fy = randInt(GRID_ROWS);
        if (isCellFree(fx, fy)) {
          food = { x: fx, y: fy };
          return;
        }
      }
    }

    function isCellFree(x, y) {
      for (const p of players) if (p.alive && p.snake.some(s => s.x === x && s.y === y)) return false;
      for (const e of enemies) if (e.alive && e.snake.some(s => s.x === x && s.y === y)) return false;
      return true;
    }

    /* -------------------------
       Input handling
       ------------------------- */
    // Prevent reversing direction instantly
    function isOpposite(a, b) { return a.x === -b.x && a.y === -b.y; }

    // Player 1: WASD
    const KEY_TO_DIR_P1 = {
      'w': { x: 0, y: -1 },
      'a': { x: -1, y: 0 },
      's': { x: 0, y: 1 },
      'd': { x: 1, y: 0 }
    };

    // Player 2: Arrow keys
    const KEY_TO_DIR_P2 = {
      'arrowup': { x: 0, y: -1 },
      'arrowleft': { x: -1, y: 0 },
      'arrowdown': { x: 0, y: 1 },
      'arrowright': { x: 1, y: 0 }
    };

    window.addEventListener('keydown', (e) => {
      if (!running) return;
      const key = e.key.toLowerCase();

      // Player 1
      if (key in KEY_TO_DIR_P1) {
        const dir = KEY_TO_DIR_P1[key];
        const p1 = players[0];
        if (p1 && p1.alive && !isOpposite(dir, p1.dir)) p1.nextDir = dir;
      }

      // Player 2 (if present)
      if (key in KEY_TO_DIR_P2) {
        const p2 = players[1];
        if (p2 && p2.alive) {
          const dir = KEY_TO_DIR_P2[key];
          if (!isOpposite(dir, p2.dir)) p2.nextDir = dir;
        }
      }

      // Prevent arrow keys from scrolling
      if (['ArrowUp','ArrowDown','ArrowLeft','ArrowRight',' '].includes(e.key)) {
        e.preventDefault();
      }
    }, { passive: false });

    /* -------------------------
       Enemy AI logic
       ------------------------- */
    // Determine enemy target: normally food, but if aggro active they target the triggering player's head
    function updateEnemyTargets() {
      for (const e of enemies) {
        if (!e.alive) continue;
        if (aggroActive) {
          e.aggro = true;
        } else {
          e.aggro = false;
        }
      }
    }

    // Compute next direction for an enemy toward its target (food or player head)
    function computeEnemyNextDir(enemy) {
      if (!enemy.alive) return { x: 0, y: 0 };
      const head = enemy.snake[0];
      let tx = food.x, ty = food.y;

      if (aggroActive && aggroTriggeringPlayerId !== null) {
        const triggeringPlayer = players.find(p => p.id === aggroTriggeringPlayerId);
        if (triggeringPlayer && triggeringPlayer.alive) {
          tx = triggeringPlayer.snake[0].x;
          ty = triggeringPlayer.snake[0].y;
        }
      }

      // Wrap-aware deltas
      let dx = tx - head.x;
      let dy = ty - head.y;
      if (Math.abs(dx) > GRID_COLS / 2) dx = dx > 0 ? dx - GRID_COLS : dx + GRID_COLS;
      if (Math.abs(dy) > GRID_ROWS / 2) dy = dy > 0 ? dy - GRID_ROWS : dy + GRID_ROWS;

      // Prefer larger axis
      if (Math.abs(dx) >= Math.abs(dy)) {
        return { x: Math.sign(dx) || 0, y: 0 };
      } else {
        return { x: 0, y: Math.sign(dy) || 0 };
      }
    }

    /* -------------------------
       Game update (single tick)
       ------------------------- */
    function updateTick() {
      if (!running) return;

      // Apply queued directions for players (no instant reverse)
      for (const p of players) {
        if (!p.alive) continue;
        if (!isOpposite(p.nextDir, p.dir)) p.dir = { ...p.nextDir };
      }

      // Update enemy targets and directions
      updateEnemyTargets();
      for (const e of enemies) {
        if (!e.alive) continue;
        const desired = computeEnemyNextDir(e);
        if (!isOpposite(desired, e.dir)) e.nextDir = desired;
        if (!isOpposite(e.nextDir, e.dir)) e.dir = { ...e.nextDir };
      }

      // Compute new heads for all actors (players then enemies)
      const newHeads = new Map(); // key actor -> new head
      for (const p of players) {
        if (!p.alive) continue;
        const head = p.snake[0];
        newHeads.set(p, { x: mod(head.x + p.dir.x, GRID_COLS), y: mod(head.y + p.dir.y, GRID_ROWS) });
      }
      for (const e of enemies) {
        if (!e.alive) continue;
        const head = e.snake[0];
        newHeads.set(e, { x: mod(head.x + e.dir.x, GRID_COLS), y: mod(head.y + e.dir.y, GRID_ROWS) });
      }

      // Collision resolution rules (simultaneous movement):
      // - If a player's new head equals any enemy segment -> player dies.
      // - If an enemy's new head equals any player's segment -> that enemy dies.
      // - If two snakes' new heads collide with each other -> both die.
      // - If a snake's new head collides with its own body -> it dies.
      // - If snakes collide with each other's bodies (not head) -> appropriate death(s).
      // We'll evaluate in a deterministic order: detect head-head collisions first, then head->body collisions.

      // 1) Head-head collisions: if two new heads occupy same cell -> both die (for any types)
      const headPositions = {};
      for (const [actor, pos] of newHeads.entries()) {
        const key = pos.x + ',' + pos.y;
        if (!headPositions[key]) headPositions[key] = [];
        headPositions[key].push(actor);
      }
      const actorsToDie = new Set();
      for (const key in headPositions) {
        const arr = headPositions[key];
        if (arr.length > 1) {
          // multiple actors moved into same cell -> all die
          for (const a of arr) actorsToDie.add(a);
        }
      }

      // 2) Head -> body collisions (new head into existing body segments BEFORE movement)
      // If player's new head equals any enemy's current segment -> player dies.
      // If enemy's new head equals any player's current segment -> enemy dies.
      for (const [actor, pos] of newHeads.entries()) {
        if (actorsToDie.has(actor)) continue; // already dying
        if (actor.type === 'player') {
          // check enemy bodies
          for (const e of enemies) {
            if (!e.alive) continue;
            if (e.snake.some(seg => seg.x === pos.x && seg.y === pos.y)) {
              actorsToDie.add(actor); // player dies
              break;
            }
          }
        } else if (actor.type === 'enemy') {
          // check player bodies (including head)
          for (const p of players) {
            if (!p.alive) continue;
            if (p.snake.some(seg => seg.x === pos.x && seg.y === pos.y)) {
              actorsToDie.add(actor); // enemy dies
              break;
            }
          }
        }
      }

      // 3) Self-collision: new head into own body (excluding tail if tail will move away)
      // For simplicity, treat as collision into any current segment (including tail) -> die
      for (const [actor, pos] of newHeads.entries()) {
        if (actorsToDie.has(actor)) continue;
        if (actor.snake.some(seg => seg.x === pos.x && seg.y === pos.y)) {
          actorsToDie.add(actor);
        }
      }

      // Apply deaths from collisions
      for (const a of actorsToDie) {
        a.alive = false;
      }

      // 4) Move actors that are still alive: add new head, handle food, pop tail if not eaten
      let foodEatenBy = null; // actor who ate food (first one)
      // Move players
      for (const p of players) {
        if (!p.alive) continue;
        const pos = newHeads.get(p);
        p.snake.unshift(pos);
        // Check food
        if (food && pos.x === food.x && pos.y === food.y) {
          p.eats += 1;
          p.consecutiveEats += 1;
          foodEatenBy = p;
          // grow like player: do not pop tail (grows by 1)
        } else {
          // normal move: remove tail
          p.snake.pop();
          p.consecutiveEats = 0;
        }
      }

      // Move enemies
      for (const e of enemies) {
        if (!e.alive) continue;
        const pos = newHeads.get(e);
        e.snake.unshift(pos);
        // Check food
        if (food && pos.x === food.x && pos.y === food.y) {
          e.eats += 1;
          e.consecutiveEats += 1;
          foodEatenBy = foodEatenBy || e; // first eater
          // grow like player: do not pop tail
        } else {
          e.snake.pop();
          e.consecutiveEats = 0;
        }
      }

      // If food was eaten by anyone, place a new food immediately
      if (foodEatenBy) {
        placeFood();
      }

      // 5) Post-move checks: if any player's snake length >= 65% of total cells -> win
      const totalCells = GRID_COLS * GRID_ROWS;
      for (const p of players) {
        if (p.alive && p.snake.length >= Math.ceil(0.65 * totalCells)) {
          endGame(true, p.id);
          return;
        }
      }

      // 6) Aggressive mode handling
      handleAggressiveMode(foodEatenBy);

      // Update UI scores
      updateScoreUI();
    }

    /* -------------------------
       Aggressive mode logic
       ------------------------- */
    function handleAggressiveMode(foodEatenBy) {
      // Determine if any player has > AGGRO_THRESHOLD consecutive eats and enemies have 0 total eats
      const enemiesHaveEaten = enemies.some(e => e.eats > 0);
      const triggeringPlayer = players.find(p => p.consecutiveEats > AGGRO_THRESHOLD);

      if (!aggroActive && triggeringPlayer && !enemiesHaveEaten) {
        // Enter aggressive mode
        aggroActive = true;
        aggroTimer = AGGRO_DURATION_MS;
        aggroTriggeringPlayerId = triggeringPlayer.id;
        aggroPlayerEatsAtStart = triggeringPlayer.eats;
        // mark enemies aggro flag
        for (const e of enemies) e.aggro = true;
      }

      if (aggroActive) {
        // If the triggering player ate 2 more dots since start, end early
        const triggerPlayer = players.find(p => p.id === aggroTriggeringPlayerId);
        if (!triggerPlayer || (triggerPlayer.eats - aggroPlayerEatsAtStart) >= AGGRO_EXTRA_EATS_TO_END) {
          endAggro();
          return;
        }

        // Decrement timer (called from main loop with delta)
        // aggroTimer is decremented in main loop; here we just check if <=0
        if (aggroTimer <= 0) {
          endAggro();
        }
      }
    }

    function endAggro() {
      aggroActive = false;
      aggroTimer = 0;
      aggroTriggeringPlayerId = null;
      aggroPlayerEatsAtStart = 0;
      for (const e of enemies) e.aggro = false;
    }

    /* -------------------------
       Rendering
       ------------------------- */
    function render() {
      // Clear
      ctx.fillStyle = '#000';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      // Draw subtle grid
      ctx.strokeStyle = COLORS.gridLine;
      ctx.lineWidth = 1;
      for (let x = 0; x <= GRID_COLS; x++) {
        ctx.beginPath();
        ctx.moveTo(x * CELL_SIZE, 0);
        ctx.lineTo(x * CELL_SIZE, canvas.height);
        ctx.stroke();
      }
      for (let y = 0; y <= GRID_ROWS; y++) {
        ctx.beginPath();
        ctx.moveTo(0, y * CELL_SIZE);
        ctx.lineTo(canvas.width, y * CELL_SIZE);
        ctx.stroke();
      }

      // Draw food
      if (food) {
        ctx.fillStyle = COLORS.food;
        drawCell(food.x, food.y);
      }

      // Draw enemies
      for (const e of enemies) {
        if (!e.alive) continue;
        const headColor = e.aggro ? COLORS.enemyGray : e.colorHead;
        const bodyColor = e.aggro ? shadeColor(COLORS.enemyGray, -20) : e.colorBody;
        for (let i = 0; i < e.snake.length; i++) {
          const seg = e.snake[i];
          ctx.fillStyle = (i === 0) ? headColor : bodyColor;
          drawCell(seg.x, seg.y);
        }
      }

      // Draw players
      for (const p of players) {
        if (!p.alive) continue;
        for (let i = 0; i < p.snake.length; i++) {
          const seg = p.snake[i];
          ctx.fillStyle = (i === 0) ? p.colorHead : p.colorBody;
          drawCell(seg.x, seg.y);
        }
      }
    }

    function drawCell(gx, gy) {
      ctx.fillRect(gx * CELL_SIZE + 1, gy * CELL_SIZE + 1, CELL_SIZE - 2, CELL_SIZE - 2);
    }

    /* -------------------------
       Main loop
       ------------------------- */
    function gameLoop(timestamp) {
      if (!lastTime) lastTime = timestamp;
      const delta = timestamp - lastTime;
      lastTime = timestamp;

      if (running) {
        moveTimer += delta;
        // decrement aggro timer if active
        if (aggroActive) aggroTimer -= delta;

        if (moveTimer >= moveInterval) {
          moveTimer = 0;
          updateTick();
        }
      }

      render();
      requestAnimationFrame(gameLoop);
    }

    /* -------------------------
       Start / Stop controls
       ------------------------- */
    function startGame() {
      // Lock settings
      settingsLocked = true;
      startBtn.disabled = true;
      stopBtn.disabled = false;
      enemyCountSelect.disabled = true;
      modeSelect.disabled = true;
      speedInput.disabled = true;

      // Configure grid & speed
      configureGrid();
      moveInterval = speedToInterval(parseInt(speedInput.value, 10));

      // Reset state
      resetGameState();

      running = true;
      lastTime = 0;
      moveTimer = 0;
    }

    function stopGame() {
      running = false;
      settingsLocked = false;
      startBtn.disabled = false;
      stopBtn.disabled = true;
      enemyCountSelect.disabled = false;
      modeSelect.disabled = false;
      speedInput.disabled = false;
      overlay.style.display = 'flex';
      overlay.textContent = 'Paused';
    }

    function endGame(playerWon, winnerId = null) {
      running = false;
      settingsLocked = false;
      startBtn.disabled = false;
      stopBtn.disabled = true;
      enemyCountSelect.disabled = false;
      modeSelect.disabled = false;
      speedInput.disabled = false;
      overlay.style.display = 'flex';
      if (playerWon) {
        overlay.textContent = `Player ${winnerId} Wins!`;
      } else {
        // Determine which players are alive; if none, generic game over
        const alivePlayers = players.filter(p => p.alive).map(p => p.id);
        if (alivePlayers.length === 1) {
          overlay.textContent = `Player ${alivePlayers[0]} Survived — Game Over`;
        } else {
          overlay.textContent = 'Game Over';
        }
      }
    }

    function updateScoreUI() {
      score1El.textContent = players[0] ? players[0].eats : 0;
      score2El.textContent = players[1] ? players[1].eats : 0;
    }

    // Convert speed slider to interval (ms)
    function speedToInterval(speed) {
      // 1 => slowest (350ms), 10 => fastest (70ms)
      return 350 - (speed - 1) * 30;
    }

    /* -------------------------
       Event wiring
       ------------------------- */
    startBtn.addEventListener('click', startGame);
    stopBtn.addEventListener('click', stopGame);

    // Prevent changing settings during gameplay
    speedInput.addEventListener('input', () => {
      if (settingsLocked) {
        speedInput.value = speedInput.defaultValue;
        return;
      }
      moveInterval = speedToInterval(parseInt(speedInput.value, 10));
    });

    enemyCountSelect.addEventListener('change', () => {
      if (settingsLocked) {
        enemyCountSelect.value = enemyCountSelect.defaultValue;
      } else {
        configureGrid();
      }
    });

    modeSelect.addEventListener('change', () => {
      if (settingsLocked) {
        modeSelect.value = modeSelect.defaultValue;
      } else {
        // nothing else; grid will be reconfigured on start
      }
    });

    /* -------------------------
       Initialization
       ------------------------- */
    configureGrid();
    resetGameState();
    requestAnimationFrame(gameLoop);

    /* -------------------------
       Notes & simplifications
       -------------------------
       - Enemy AI is greedy: moves along the larger axis toward target (food or triggering player's head).
       - Enemies grow exactly like players (one segment per food).
       - Collisions are resolved deterministically: head-head -> both die; head->body -> appropriate death.
       - Aggressive mode triggers when any player has >5 consecutive eats and enemies have 0 total eats.
       - Aggressive mode lasts 10s or until triggering player eats 2 more dots.
       - Settings (speed, enemies, mode) are locked while the game runs.
       - Code is organized into sections: input, game logic, AI, rendering.
       ************************************************************************/
  </script>
</body>
</html>
