<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>The ANT Snake — A-Frame 3D</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <script src="https://aframe.io/releases/1.4.2/aframe.min.js"></script>
  <script src="https://unpkg.com/simplex-noise@2.4.0/simplex-noise.min.js"></script>
  <style>
    body { margin: 0; background: #00131f; font-family: "Courier New", monospace; }
    .hint { position: absolute; left: 12px; bottom: 12px; color: #9fd; font-size: 13px; z-index: 10; }
  </style>
</head>
<body>
  <div class="hint">Drag to orbit, scroll to zoom. Click UI panels to interact.</div>

  <a-scene background="color: #001a33" vr-mode-ui="enabled: false" renderer="antialias: true">
    <!-- Ocean-like skybox (large sphere with animated material) -->
    <a-entity id="ocean" geometry="primitive: sphere; radius: 5000; segmentsWidth: 32; segmentsHeight: 32"
              material="shader: flat; color: #002b55; side: back; opacity: 0.98"
              ocean-shader></a-entity>

    <!-- Lights -->
    <a-entity light="type: ambient; intensity: 0.6"></a-entity>
    <a-entity light="type: directional; intensity: 0.9" position="1 2 1"></a-entity>

    <!-- Land sphere (coffee brown) with bumpiness -->
    <a-entity id="land" geometry="primitive: sphere; radius: 3; segmentsWidth: 128; segmentsHeight: 128"
              material="color: #6b4b2b; metalness:0.1; roughness:0.9; shader: standard"
              bumpy-sphere></a-entity>

    <!-- Container for all dynamic actors (snakes, food) -->
    <a-entity id="actors"></a-entity>

    <!-- UI Panel group (in-scene) -->
    <a-entity id="uiRoot" position="-1.6 1.6 -3" rotation="0 15 0">
      <!-- Background plane -->
      <a-plane width="1.6" height="1.9" color="#071017" material="opacity:0.95"></a-plane>

      <!-- Title -->
      <a-text value="The ANT Snake" color="#00ff00" align="center" position="0 0.78 0.01" width="1.4" wrap-count="18" ></a-text>

      <!-- Speed label + slider -->
      <a-text value="Speed (1-10)" color="#cfe" align="left" position="-0.7 0.58 0.01" width="1.4"></a-text>
      <a-entity id="speedSlider" position="0 0.48 0.02" ui-slider="min:1;max:10;value:5"></a-entity>

      <!-- Enemy selector -->
      <a-text value="Enemies (0-3)" color="#cfe" align="left" position="-0.7 0.28 0.01" width="1.4"></a-text>
      <a-entity id="enemySelector" position="0 0.18 0.02" ui-select="options:0,1,2,3;value:1"></a-entity>

      <!-- Mode selector -->
      <a-text value="Mode" color="#cfe" align="left" position="-0.7 -0.02 0.01" width="1.4"></a-text>
      <a-entity id="modeSelector" position="0 -0.12 0.02" ui-select="options:1,2;labels:1 Player,2 Players;value:1"></a-entity>

      <!-- Start / Stop buttons -->
      <a-entity id="buttons" position="0 -0.44 0.02">
        <a-box id="startBtn" depth="0.04" height="0.18" width="0.7" color="#111" position="-0.4 0 0" class="clickable"></a-box>
        <a-text value="Start" color="#9fd" align="center" position="-0.4 0 0.03" width="0.6"></a-text>

        <a-box id="stopBtn" depth="0.04" height="0.18" width="0.7" color="#111" position="0.4 0 0" class="clickable"></a-box>
        <a-text value="Stop" color="#9fd" align="center" position="0.4 0 0.03" width="0.6"></a-text>
      </a-entity>

      <!-- Score display -->
      <a-text id="scoreText" value="Score P1: 0   P2: 0" color="#cfe" align="left" position="-0.7 -0.78 0.01" width="1.4"></a-text>

      <!-- Legend -->
      <a-text value="Controls: P1 W A S D  P2 Arrows" color="#9aa" align="left" position="-0.7 -1.02 0.01" width="1.4"></a-text>
      <a-text value="Win: cover 65% of sphere" color="#9aa" align="left" position="-0.7 -1.18 0.01" width="1.4"></a-text>
    </a-entity>

    <!-- Camera rig with orbit component -->
    <a-entity id="cameraRig" position="0 0 8" orbit-camera>
      <a-entity camera look-controls="enabled:false"></a-entity>
      <!-- Cursor for UI interaction -->
      <a-entity cursor="fuse:false; rayOrigin: mouse" raycaster="objects: .clickable, .ui" position="0 0 0"></a-entity>
    </a-entity>

    <!-- Ground reference (invisible) to keep scene centered -->
    <a-entity position="0 -3 0"></a-entity>
  </a-scene>

  <script>
  /*
    The ANT Snake — A-Frame 3D rewrite
    - All UI is inside the A-Frame scene (no external HTML controls).
    - Modular components:
      * bumpy-sphere: creates animated bumpiness on the land sphere
      * ocean-shader: subtle animated ocean background (simple color animation)
      * orbit-camera: mouse orbit and zoom
      * ui-slider, ui-select: interactive UI widgets inside scene
      * game-manager: orchestrates game logic, snake movement, enemy AI, collisions, UI events
    - Snakes move on a spherical grid (cols x rows). Movement rules mirror the 2D version but mapped to sphere.
  */

  // -------------------------
  // Utility helpers
  // -------------------------
  function mod(n,m){ return ((n % m) + m) % m; }
  function randInt(n){ return Math.floor(Math.random()*n); }
  function clamp(v,a,b){ return Math.max(a, Math.min(b, v)); }
  function shadeColor(hex, delta){
    const num = parseInt(hex.slice(1),16);
    let r = (num>>16) + delta;
    let g = ((num>>8)&0xff) + delta;
    let b = (num & 0xff) + delta;
    r = Math.max(0,Math.min(255,r));
    g = Math.max(0,Math.min(255,g));
    b = Math.max(0,Math.min(255,b));
    return '#' + ((r<<16)|(g<<8)|b).toString(16).padStart(6,'0');
  }

  // -------------------------
  // Ocean shader (simple animated color)
  // -------------------------
  AFRAME.registerComponent('ocean-shader', {
    init: function(){
      this.start = performance.now();
      this.el.object3D.rotation.y = 0;
    },
    tick: function(t, dt){
      const elapsed = (t - this.start) / 1000;
      // subtle color shift to simulate movement
      const b = 0.15 + Math.sin(elapsed * 0.2) * 0.05;
      const g = 0.35 + Math.cos(elapsed * 0.15) * 0.05;
      this.el.setAttribute('material', 'color', `rgb(${Math.floor(0*b*255)}, ${Math.floor(20*g*255)}, ${Math.floor(85*255)})`);
      // slow rotation for parallax
      this.el.object3D.rotation.y = elapsed * 0.01;
    }
  });

  // -------------------------
  // Bumpy sphere component
  // - Uses simplex noise to displace vertices slightly
  // - Random seed each start; slight animation
  // -------------------------
  AFRAME.registerComponent('bumpy-sphere', {
    schema: { amplitude: { type: 'number', default: 0.12 }, speed: { type: 'number', default: 0.6 } },
    init: function(){
      // Wait for mesh to be available
      this.mesh = this.el.getObject3D('mesh');
      if (!this.mesh) {
        this.el.addEventListener('object3dset', () => { this.mesh = this.el.getObject3D('mesh'); this.setup(); });
      } else this.setup();
    },
    setup: function(){
      this.geometry = this.mesh.geometry;
      // copy base positions
      this.basePos = new Float32Array(this.geometry.attributes.position.array);
      this.simplex = new SimplexNoise(Math.random());
      this.vertexCount = this.geometry.attributes.position.count;
      this.noiseSeed = new Float32Array(this.vertexCount);
      for (let i=0;i<this.vertexCount;i++) this.noiseSeed[i] = Math.random() * 10;
      this.start = performance.now();
    },
    tick: function(time){
      if (!this.geometry || !this.basePos) return;
      const pos = this.geometry.attributes.position.array;
      const amp = this.data.amplitude;
      const speed = this.data.speed;
      const t = (time - this.start) / 1000;
      for (let i=0;i<this.vertexCount;i++){
        const bx = this.basePos[i*3], by = this.basePos[i*3+1], bz = this.basePos[i*3+2];
        // compute noise based on base position and time
        const n = this.simplex.noise3D(bx*0.5 + this.noiseSeed[i], by*0.5, t*0.2*speed);
        const factor = 1 + n * amp * 0.6;
        pos[i*3] = bx * factor;
        pos[i*3+1] = by * factor;
        pos[i*3+2] = bz * factor;
      }
      this.geometry.attributes.position.needsUpdate = true;
      this.geometry.computeVertexNormals();
    }
  });

  // -------------------------
  // Orbit camera component
  // - Mouse drag rotates around sphere
  // - Wheel zooms
  // -------------------------
  AFRAME.registerComponent('orbit-camera', {
    schema: { distance: { type: 'number', default: 8 }, sensitivity: { type: 'number', default: 0.9 } },
    init: function(){
      this.theta = 0;
      this.phi = Math.PI/6;
      this.distance = this.data.distance;
      this.dragging = false;
      this.last = {x:0,y:0};
      const canvas = this.el.sceneEl.canvas;
      const onDown = (e) => { this.dragging = true; this.last.x = e.clientX; this.last.y = e.clientY; };
      const onUp = () => { this.dragging = false; };
      const onMove = (e) => {
        if (!this.dragging) return;
        const dx = e.clientX - this.last.x;
        const dy = e.clientY - this.last.y;
        this.last.x = e.clientX; this.last.y = e.clientY;
        this.theta -= dx * 0.005 * this.data.sensitivity;
        this.phi = clamp(this.phi - dy * 0.005 * this.data.sensitivity, 0.05, Math.PI - 0.05);
      };
      const onWheel = (e) => {
        this.distance = clamp(this.distance + e.deltaY * 0.01, 4.0, 14.0);
      };
      // attach after canvas ready
      const attach = () => {
        const c = this.el.sceneEl.canvas;
        if (!c) { setTimeout(attach, 50); return; }
        c.addEventListener('mousedown', onDown);
        window.addEventListener('mouseup', onUp);
        window.addEventListener('mousemove', onMove);
        c.addEventListener('wheel', onWheel, {passive:true});
      };
      attach();
    },
    tick: function(){
      // smooth interpolation could be added; set position directly
      const x = this.distance * Math.sin(this.phi) * Math.cos(this.theta);
      const z = this.distance * Math.sin(this.phi) * Math.sin(this.theta);
      const y = this.distance * Math.cos(this.phi);
      this.el.setAttribute('position', { x, y, z });
      // ensure camera looks at center
      const cam = this.el.querySelector('[camera]');
      if (cam) cam.object3D.lookAt(0,0,0);
    }
  });

  // -------------------------
  // UI slider component (3D)
  // - Renders a simple slider with clickable left/right arrows
  // - Emits 'change' events with new value
  // -------------------------
  AFRAME.registerComponent('ui-slider', {
    schema: { min: {type:'number', default:1}, max:{type:'number', default:10}, value:{type:'number', default:5} },
    init: function(){
      const el = this.el;
      const data = this.data;
      // create visual elements
      const left = document.createElement('a-box'); left.setAttribute('width',0.12); left.setAttribute('height',0.12); left.setAttribute('depth',0.04); left.setAttribute('color','#222'); left.classList.add('clickable','ui');
      left.setAttribute('position','-0.36 0 0'); el.appendChild(left);
      const right = document.createElement('a-box'); right.setAttribute('width',0.12); right.setAttribute('height',0.12); right.setAttribute('depth',0.04); right.setAttribute('color','#222'); right.classList.add('clickable','ui');
      right.setAttribute('position','0.36 0 0'); el.appendChild(right);
      const bar = document.createElement('a-plane'); bar.setAttribute('width',0.6); bar.setAttribute('height',0.08); bar.setAttribute('color','#111'); bar.setAttribute('position','0 0 0.01'); el.appendChild(bar);
      const knob = document.createElement('a-box'); knob.setAttribute('width',0.08); knob.setAttribute('height',0.12); knob.setAttribute('depth',0.06); knob.setAttribute('color','#9fd'); knob.setAttribute('position','0 0 0.03'); el.appendChild(knob);
      const label = document.createElement('a-text'); label.setAttribute('value', data.value.toString()); label.setAttribute('color','#cfe'); label.setAttribute('align','center'); label.setAttribute('position','0 -0.18 0.02'); label.setAttribute('width',0.8); el.appendChild(label);
      this.knob = knob; this.label = label;
      this.updateKnob();

      // click handlers
      left.addEventListener('click', () => { this.setValue(this.data.value - 1); });
      right.addEventListener('click', () => { this.setValue(this.data.value + 1); });

      // expose method
      el.setValue = (v) => this.setValue(v);
    },
    setValue: function(v){
      v = Math.round(clamp(v, this.data.min, this.data.max));
      this.data.value = v;
      this.updateKnob();
      this.el.emit('change', { value: v });
    },
    updateKnob: function(){
      const t = (this.data.value - this.data.min) / (this.data.max - this.data.min);
      const x = (t - 0.5) * 0.6;
      this.knob.setAttribute('position', `${x} 0 0.03`);
      this.label.setAttribute('value', this.data.value.toString());
    }
  });

  // -------------------------
  // UI select component (simple)
  // - options: comma-separated values
  // - labels optional (comma-separated)
  // - emits 'change' events
  // -------------------------
  AFRAME.registerComponent('ui-select', {
    schema: { options: {type:'string', default:'0,1,2,3'}, labels:{type:'string', default:''}, value:{type:'string', default:''} },
    init: function(){
      const el = this.el;
      const opts = this.data.options.split(',');
      const labels = this.data.labels ? this.data.labels.split(',') : [];
      this.index = opts.indexOf(this.data.value.toString());
      if (this.index < 0) this.index = 0;
      // left/right boxes and label
      const left = document.createElement('a-box'); left.setAttribute('width',0.12); left.setAttribute('height',0.12); left.setAttribute('depth',0.04); left.setAttribute('color','#222'); left.classList.add('clickable','ui'); left.setAttribute('position','-0.36 0 0'); el.appendChild(left);
      const right = document.createElement('a-box'); right.setAttribute('width',0.12); right.setAttribute('height',0.12); right.setAttribute('depth',0.04); right.setAttribute('color','#222'); right.classList.add('clickable','ui'); right.setAttribute('position','0.36 0 0'); el.appendChild(right);
      const label = document.createElement('a-text'); label.setAttribute('value', labels[this.index] || opts[this.index]); label.setAttribute('color','#cfe'); label.setAttribute('align','center'); label.setAttribute('position','0 0 0.02'); label.setAttribute('width',0.9); el.appendChild(label);
      this.opts = opts; this.labels = labels; this.label = label;
      left.addEventListener('click', () => { this.index = (this.index - 1 + opts.length) % opts.length; this.update(); });
      right.addEventListener('click', () => { this.index = (this.index + 1) % opts.length; this.update(); });
      this.update();
    },
    update: function(){
      const val = this.opts[this.index];
      this.el.emit('change', { value: val });
      this.label.setAttribute('value', this.labels[this.index] || val);
    },
    getValue: function(){ return this.opts[this.index]; }
  });

  // -------------------------
  // Game manager component
  // - Implements game logic, snake movement on sphere grid, enemy AI, UI integration
  // -------------------------
  AFRAME.registerComponent('game-manager', {
    init: function(){
      // configuration
      this.STANDARD_COLS = 24;
      this.STANDARD_ROWS = 16;
      this.players = []; // player objects
      this.enemies = [];
      this.food = null;
      this.running = false;
      this.moveInterval = 200;
      this.moveTimer = 0;
      this.lastTime = null;
      this.aggroActive = false;
      this.aggroTimer = 0;
      this.aggroTriggerPlayerId = null;
      this.aggroPlayerEatsAtStart = 0;

      // colors
      this.COLORS = {
        player1Head: '#9aff9a', player1Body: '#2ecc40',
        player2Head: '#ffd86b', player2Body: '#ffcc00',
        food: '#ff4444',
        enemyColors: ['#66ccff','#ff66cc','#ffcc66'],
        enemyGray: '#888888'
      };

      // references
      this.landEl = document.getElementById('land');
      this.actorsEl = document.getElementById('actors');
      this.uiRoot = document.getElementById('uiRoot');
      this.speedSlider = document.getElementById('speedSlider');
      this.enemySelector = document.getElementById('enemySelector');
      this.modeSelector = document.getElementById('modeSelector');
      this.startBtn = document.getElementById('startBtn');
      this.stopBtn = document.getElementById('stopBtn');
      this.scoreText = document.getElementById('scoreText');

      // grid size (adjusted on start)
      this.GRID_COLS = this.STANDARD_COLS;
      this.GRID_ROWS = this.STANDARD_ROWS;
      this.SPHERE_RADIUS = 3.0;
      this.SEGMENT_SIZE = 0.18;
      this.SURFACE_OFFSET = 0.12;

      // bind UI events
      this.bindUI();

      // keyboard input
      window.addEventListener('keydown', (e) => this.onKeyDown(e));

      // start tick
      this.el.sceneEl.addEventListener('loaded', () => {
        this.lastTime = performance.now();
        this.tick();
      });
    },

    bindUI: function(){
      // slider change
      this.speedSlider.addEventListener('change', (evt) => {
        const v = evt.detail.value;
        this.moveInterval = this.speedToInterval(v);
      });
      // selectors
      this.enemySelector.addEventListener('change', (evt) => { /* nothing immediate */ });
      this.modeSelector.addEventListener('change', (evt) => { /* nothing immediate */ });

      // start/stop clickable boxes
      this.startBtn.addEventListener('click', () => this.startGame());
      this.stopBtn.addEventListener('click', () => this.stopGame());
    },

    // convert slider speed to interval (ms)
    speedToInterval: function(speed){
      return 350 - (speed - 1) * 30;
    },

    // keyboard controls (WASD and arrows)
    onKeyDown: function(e){
      if (!this.running) return;
      const key = e.key.toLowerCase();
      // player 1
      const p1 = this.players[0];
      if (p1 && p1.alive){
        if (key === 'w') this.trySetNextDir(p1, {x:0,y:-1});
        if (key === 's') this.trySetNextDir(p1, {x:0,y:1});
        if (key === 'a') this.trySetNextDir(p1, {x:-1,y:0});
        if (key === 'd') this.trySetNextDir(p1, {x:1,y:0});
      }
      // player 2
      const p2 = this.players[1];
      if (p2 && p2.alive){
        if (key === 'arrowup') this.trySetNextDir(p2, {x:0,y:-1});
        if (key === 'arrowdown') this.trySetNextDir(p2, {x:0,y:1});
        if (key === 'arrowleft') this.trySetNextDir(p2, {x:-1,y:0});
        if (key === 'arrowright') this.trySetNextDir(p2, {x:1,y:0});
      }
    },

    trySetNextDir: function(actor, dir){
      if (!actor) return;
      if (this.isOpposite(dir, actor.dir)) return;
      actor.nextDir = dir;
    },

    isOpposite: function(a,b){ return a.x === -b.x && a.y === -b.y; },

    // start game: lock UI, configure grid, spawn actors
    startGame: function(){
      // lock UI visuals (dim start)
      this.startBtn.setAttribute('color','#333');
      this.stopBtn.setAttribute('color','#111');
      // configure grid size based on enemy count
      const enemyCount = parseInt(this.enemySelector.components['ui-select'].opts[this.enemySelector.components['ui-select'].index]);
      if (enemyCount <= 1){ this.GRID_COLS = this.STANDARD_COLS; this.GRID_ROWS = this.STANDARD_ROWS; }
      else { this.GRID_COLS = this.STANDARD_COLS * 2; this.GRID_ROWS = this.STANDARD_ROWS * 2; }
      // set move interval from slider
      const speedVal = this.speedSlider.components['ui-slider'].data.value;
      this.moveInterval = this.speedToInterval(speedVal);
      // reset state and spawn
      this.resetState();
      this.spawnActors();
      this.running = true;
      // set bumpy-sphere randomization each start
      const amp = 0.06 + Math.random()*0.14;
      const spd = 0.3 + Math.random()*1.0;
      this.landEl.setAttribute('bumpy-sphere', { amplitude: amp, speed: spd });
    },

    stopGame: function(){
      this.running = false;
      this.startBtn.setAttribute('color','#111');
      this.stopBtn.setAttribute('color','#333');
      this.showMessage('Paused');
    },

    resetState: function(){
      // clear actors
      while (this.actorsEl.firstChild) this.actorsEl.removeChild(this.actorsEl.firstChild);
      this.players = []; this.enemies = []; this.food = null;
      this.aggroActive = false; this.aggroTimer = 0; this.aggroTriggerPlayerId = null; this.aggroPlayerEatsAtStart = 0;
      this.updateScoreUI();
      this.showMessage('');
    },

    spawnActors: function(){
      // spawn players
      const midC = Math.floor(this.GRID_COLS/2);
      const midR = Math.floor(this.GRID_ROWS/2);
      this.players.push(this.createPlayer(1, midC, midR, {x:1,y:0}, this.COLORS.player1Head, this.COLORS.player1Body));
      const mode = parseInt(this.modeSelector.components['ui-select'].opts[this.modeSelector.components['ui-select'].index]);
      if (mode === 2) this.players.push(this.createPlayer(2, midC, midR + 3, {x:1,y:0}, this.COLORS.player2Head, this.COLORS.player2Body));

      // spawn enemies robustly
      const enemyCount = parseInt(this.enemySelector.components['ui-select'].opts[this.enemySelector.components['ui-select'].index]);
      for (let i=0;i<enemyCount;i++){
        const spawn = this.findSpawnForLength(3);
        if (spawn) this.enemies.push(this.createEnemy(i+1, spawn.col, spawn.row, spawn.dir, this.COLORS.enemyColors[i % this.COLORS.enemyColors.length]));
        else {
          // fallback: random free cell
          for (let attempts=0; attempts<1000; attempts++){
            const c = randInt(this.GRID_COLS), r = randInt(this.GRID_ROWS);
            if (!this.isCellOccupied(c,r)){ this.enemies.push(this.createEnemy(i+1, c, r, {x:-1,y:0}, this.COLORS.enemyColors[i % this.COLORS.enemyColors.length])); break; }
          }
        }
      }

      // create segment entities for each snake
      for (const p of this.players) this.createSegmentEntitiesFor(p);
      for (const e of this.enemies) this.createSegmentEntitiesFor(e);

      // spawn initial food
      this.placeFoodRandom();
      this.updateAllSegmentPositions();
      this.updateScoreUI();
    },

    createPlayer: function(id, col, row, dir, headColor, bodyColor){
      return { id, type:'player', snake: [ {col,row}, {col:mod(col-1,this.GRID_COLS), row}, {col:mod(col-2,this.GRID_COLS), row} ], dir, nextDir:{...dir}, colorHead:headColor, colorBody:bodyColor, alive:true, eats:0, consecutiveEats:0, segmentEls:[] };
    },

    createEnemy: function(id, col, row, dir, color){
      return { id, type:'enemy', snake: [ {col,row}, {col:mod(col-1,this.GRID_COLS), row}, {col:mod(col-2,this.GRID_COLS), row} ], dir, nextDir:{...dir}, colorHead:color, colorBody:shadeColor(color,-20), alive:true, eats:0, consecutiveEats:0, aggro:false, segmentEls:[] };
    },

    createSegmentEntitiesFor: function(actor){
      actor.segmentEls = [];
      for (let i=0;i<actor.snake.length;i++){
        const color = (i===0) ? actor.colorHead : actor.colorBody;
        const el = document.createElement('a-box');
        el.setAttribute('width', this.SEGMENT_SIZE);
        el.setAttribute('height', this.SEGMENT_SIZE);
        el.setAttribute('depth', this.SEGMENT_SIZE);
        el.setAttribute('material', `color: ${color}; metalness:0.2; roughness:0.6`);
        this.actorsEl.appendChild(el);
        actor.segmentEls.push(el);
      }
    },

    // grid -> spherical mapping helpers
    gridToSpherical: function(col,row){
      const theta = (col / this.GRID_COLS) * Math.PI * 2; // longitude
      const phi = (row / this.GRID_ROWS) * Math.PI;       // latitude
      return { theta, phi };
    },
    sphericalToCartesian: function(theta, phi, radius){
      const x = radius * Math.sin(phi) * Math.cos(theta);
      const z = radius * Math.sin(phi) * Math.sin(theta);
      const y = radius * Math.cos(phi);
      return { x, y, z };
    },
    surfacePosition: function(col,row, offset){
      const s = this.gridToSpherical(col,row);
      return this.sphericalToCartesian(s.theta, s.phi, this.SPHERE_RADIUS + (offset || this.SURFACE_OFFSET));
    },

    // spawn food at random free cell
    placeFoodRandom: function(){
      for (let attempts=0; attempts<10000; attempts++){
        const c = randInt(this.GRID_COLS), r = randInt(this.GRID_ROWS);
        if (!this.isCellOccupied(c,r)){
          this.placeFood(c,r); return;
        }
      }
    },
    placeFood: function(col,row){
      if (this.food && this.food.el) this.actorsEl.removeChild(this.food.el);
      const pos = this.surfacePosition(col,row, this.SURFACE_OFFSET + 0.02);
      const el = document.createElement('a-sphere');
      el.setAttribute('radius', this.SEGMENT_SIZE * 0.6);
      el.setAttribute('position', `${pos.x} ${pos.y} ${pos.z}`);
      el.setAttribute('material', `color: ${this.COLORS.food}; emissive: #ff6666; emissiveIntensity: 0.4`);
      this.actorsEl.appendChild(el);
      this.food = { col, row, el };
    },

    // occupancy checks
    isCellOccupied: function(col,row){
      for (const p of this.players) if (p.alive && p.snake.some(s => s.col === col && s.row === row)) return true;
      for (const e of this.enemies) if (e.alive && e.snake.some(s => s.col === col && s.row === row)) return true;
      return false;
    },

    // find spawn for length L
    findSpawnForLength: function(len){
      const dirs = [{x:1,y:0},{x:-1,y:0},{x:0,y:1},{x:0,y:-1}];
      for (let c=0;c<this.GRID_COLS;c++){
        for (let r=0;r<this.GRID_ROWS;r++){
          for (const d of dirs){
            let ok = true;
            let cx = c, cy = r;
            for (let i=0;i<len;i++){
              if (this.isCellOccupied(cx,cy)) { ok = false; break; }
              cx = mod(cx - d.x, this.GRID_COLS);
              cy = mod(cy - d.y, this.GRID_ROWS);
            }
            if (ok) return { col:c, row:r, dir:d };
          }
        }
      }
      return null;
    },

    // update all segment positions (render)
    updateAllSegmentPositions: function(){
      const updateActor = (actor) => {
        for (let i=0;i<actor.segmentEls.length;i++){
          const seg = actor.snake[i];
          const el = actor.segmentEls[i];
          if (!seg){ el.setAttribute('visible', false); continue; }
          const pos = this.surfacePosition(seg.col, seg.row);
          el.setAttribute('position', `${pos.x} ${pos.y} ${pos.z}`);
          // orient to surface normal
          const n = this.normalize(pos);
          el.object3D.lookAt(pos.x + n.x, pos.y + n.y, pos.z + n.z);
          el.setAttribute('visible', true);
        }
      };
      for (const p of this.players) updateActor(p);
      for (const e of this.enemies) updateActor(e);
      if (this.food && this.food.el){
        const pos = this.surfacePosition(this.food.col, this.food.row, this.SURFACE_OFFSET + 0.02);
        this.food.el.setAttribute('position', `${pos.x} ${pos.y} ${pos.z}`);
      }
    },

    normalize: function(v){
      const len = Math.sqrt(v.x*v.x + v.y*v.y + v.z*v.z) || 1;
      return { x: v.x/len, y: v.y/len, z: v.z/len };
    },

    // -------------------------
    // Enemy AI (improved)
    // - predictOccupiedSets(steps)
    // - chooseEnemyDirection(enemy)
    // -------------------------
    predictOccupiedSets: function(steps){
      const actors = [...this.players, ...this.enemies].filter(a => a.alive);
      const clones = actors.map(a => ({ snake: a.snake.map(s => ({col:s.col,row:s.row})), dir: {x:a.dir.x,y:a.dir.y} }));
      const predicted = [];
      for (let step=1; step<=steps; step++){
        const occ = new Set();
        const nextHeads = clones.map(c => {
          const head = c.snake[0];
          return { col: mod(head.col + c.dir.x, this.GRID_COLS), row: mod(head.row + c.dir.y, this.GRID_ROWS) };
        });
        for (let i=0;i<clones.length;i++){
          const c = clones[i];
          const nh = nextHeads[i];
          const newSnake = [nh, ...c.snake.slice(0, c.snake.length - 1)];
          for (const seg of newSnake) occ.add(seg.col + ',' + seg.row);
          c.snake = newSnake;
        }
        predicted.push(occ);
      }
      return predicted;
    },

    countFreeNeighbors: function(col,row,selfActor){
      const neighbors = [{x:1,y:0},{x:-1,y:0},{x:0,y:1},{x:0,y:-1}];
      let count = 0;
      for (const n of neighbors){
        const nx = mod(col + n.x, this.GRID_COLS);
        const ny = mod(row + n.y, this.GRID_ROWS);
        let occupied = false;
        for (const p of this.players) if (p.alive && p.snake.some(s => s.col === nx && s.row === ny)) { occupied = true; break; }
        if (occupied) continue;
        for (const e of this.enemies) if (e.alive && e !== selfActor && e.snake.some(s => s.col === nx && s.row === ny)) { occupied = true; break; }
        if (occupied) continue;
        const tail = selfActor.snake[selfActor.snake.length - 1];
        if (tail && tail.col === nx && tail.row === ny) { count++; continue; }
        count++;
      }
      return count;
    },

    isTileCurrentlyOccupied: function(col,row,selfActor){
      for (const p of this.players) if (p.alive && p.snake.some((s,idx) => !(selfActor && selfActor === p && idx === p.snake.length - 1) && s.col === col && s.row === row)) return true;
      for (const e of this.enemies) if (e.alive && e !== selfActor && e.snake.some(s => s.col === col && s.row === row)) return true;
      if (selfActor){
        for (let i=0;i<selfActor.snake.length-1;i++){
          const s = selfActor.snake[i];
          if (s.col === col && s.row === row) return true;
        }
      }
      return false;
    },

    chooseEnemyDirection: function(enemy){
      if (!enemy.alive) return enemy.dir;
      const head = enemy.snake[0];
      const currentDir = enemy.dir;
      const POSSIBLE_DIRS = [{x:1,y:0},{x:-1,y:0},{x:0,y:1},{x:0,y:-1}];
      const candidates = POSSIBLE_DIRS.filter(d => !this.isOpposite(d,currentDir));
      const predicted = this.predictOccupiedSets(2);
      let best = null, bestScore = -Infinity;
      const randomness = 0.15;
      for (const cand of candidates){
        const pos1 = { col: mod(head.col + cand.x, this.GRID_COLS), row: mod(head.row + cand.y, this.GRID_ROWS) };
        const pos2 = { col: mod(pos1.col + cand.x, this.GRID_COLS), row: mod(pos1.row + cand.y, this.GRID_ROWS) };
        const key1 = pos1.col + ',' + pos1.row;
        const key2 = pos2.col + ',' + pos2.row;
        let danger = 0;
        for (const a of [...this.players, ...this.enemies]){ if (!a.alive || a === enemy) continue; if (a.snake.some(seg => seg.col === pos1.col && seg.row === pos1.row)) danger += 1000; }
        if (predicted[0].has(key1)) danger += 300;
        if (predicted[1].has(key2)) danger += 120;
        for (const a of [...this.players, ...this.enemies]){ if (!a.alive || a === enemy) continue; const otherHead = a.snake[0]; const otherNext = { col: mod(otherHead.col + a.dir.x, this.GRID_COLS), row: mod(otherHead.row + a.dir.y, this.GRID_ROWS) }; if (otherNext.col === pos1.col && otherNext.row === pos1.row) danger += 400; }
        const escapes1 = this.countFreeNeighbors(pos1.col, pos1.row, enemy);
        const escapes2 = this.countFreeNeighbors(pos2.col, pos2.row, enemy);
        danger += Math.max(0, (3 - escapes1)) * 40;
        danger += Math.max(0, (3 - escapes2)) * 20;
        const foodDist = Math.abs(pos1.col - this.food.col) + Math.abs(pos1.row - this.food.row);
        const foodScore = (this.GRID_COLS + this.GRID_ROWS) - foodDist;
        const survivalWeight = 1.0, foodWeight = 0.6;
        let score = (foodScore * foodWeight) - (danger * survivalWeight);
        score += (Math.random() - 0.5) * randomness * Math.abs(score + 1);
        if (danger >= 800) score -= 10000;
        if (score > bestScore){ bestScore = score; best = cand; }
      }
      if (!best){
        for (const d of [{x:1,y:0},{x:-1,y:0},{x:0,y:1},{x:0,y:-1}]){
          if (this.isOpposite(d,currentDir)) continue;
          const nx = mod(head.col + d.x, this.GRID_COLS), ny = mod(head.row + d.y, this.GRID_ROWS);
          if (!this.isTileCurrentlyOccupied(nx,ny,enemy)){ best = d; break; }
        }
        if (!best) best = currentDir;
      }
      return best;
    },

    // -------------------------
    // Movement tick: apply directions, detect collisions, move snakes, spawn food, check win
    // -------------------------
    updateTick: function(){
      if (!this.running) return;
      // apply queued directions for players
      for (const p of this.players) if (p.alive && !this.isOpposite(p.nextDir, p.dir)) p.dir = {...p.nextDir};
      // enemy AI choose directions
      for (const e of this.enemies) if (e.alive){
        const chosen = this.chooseEnemyDirection(e);
        if (chosen && !this.isOpposite(chosen, e.dir)) e.nextDir = chosen;
        if (!this.isOpposite(e.nextDir, e.dir)) e.dir = {...e.nextDir};
      }
      // compute new heads
      const actors = [...this.players, ...this.enemies].filter(a => a.alive);
      const newHeads = new Map();
      for (const a of actors){
        const head = a.snake[0];
        newHeads.set(a, { col: mod(head.col + a.dir.x, this.GRID_COLS), row: mod(head.row + a.dir.y, this.GRID_ROWS) });
      }
      // collision detection
      const posMap = {};
      for (const [actor,pos] of newHeads.entries()){
        const key = pos.col + ',' + pos.row;
        if (!posMap[key]) posMap[key] = [];
        posMap[key].push(actor);
      }
      const toDie = new Set();
      // head-head
      for (const key in posMap){ const arr = posMap[key]; if (arr.length > 1) for (const a of arr) toDie.add(a); }
      // head -> other current body
      const aliveActors = actors;
      for (const [actor,pos] of newHeads.entries()){
        if (toDie.has(actor)) continue;
        for (const other of aliveActors){
          if (other === actor) continue;
          if (other.snake.some(seg => seg.col === pos.col && seg.row === pos.row)){ toDie.add(actor); break; }
        }
      }
      // self-collision
      for (const [actor,pos] of newHeads.entries()){
        if (toDie.has(actor)) continue;
        if (actor.snake.some(seg => seg.col === pos.col && seg.row === pos.row)) toDie.add(actor);
      }
      // apply deaths
      for (const a of toDie) a.alive = false;
      // if no snakes remain alive -> game over
      const anyPlayerAlive = this.players.some(p => p.alive);
      const anyEnemyAlive = this.enemies.some(e => e.alive);
      if (!anyPlayerAlive && !anyEnemyAlive){ this.endGame(false, null); return; }
      // move surviving actors
      let foodEatenBy = null;
      for (const p of this.players){
        if (!p.alive) continue;
        const pos = newHeads.get(p);
        p.snake.unshift({col: pos.col, row: pos.row});
        if (this.food && pos.col === this.food.col && pos.row === this.food.row){
          p.eats++; p.consecutiveEats++; foodEatenBy = p;
          // add segment entity
          const seg = document.createElement('a-box'); seg.setAttribute('width', this.SEGMENT_SIZE); seg.setAttribute('height', this.SEGMENT_SIZE); seg.setAttribute('depth', this.SEGMENT_SIZE); seg.setAttribute('material', `color: ${p.colorBody}`); this.actorsEl.appendChild(seg); p.segmentEls.push(seg);
        } else { p.snake.pop(); p.consecutiveEats = 0; }
      }
      for (const e of this.enemies){
        if (!e.alive) continue;
        const pos = newHeads.get(e);
        e.snake.unshift({col: pos.col, row: pos.row});
        if (this.food && pos.col === this.food.col && pos.row === this.food.row){
          e.eats++; e.consecutiveEats++; foodEatenBy = foodEatenBy || e;
          const seg = document.createElement('a-box'); seg.setAttribute('width', this.SEGMENT_SIZE); seg.setAttribute('height', this.SEGMENT_SIZE); seg.setAttribute('depth', this.SEGMENT_SIZE); seg.setAttribute('material', `color: ${e.colorBody}`); this.actorsEl.appendChild(seg); e.segmentEls.push(seg);
        } else { e.snake.pop(); e.consecutiveEats = 0; }
      }
      // remove visuals for dead actors
      for (const a of [...this.players, ...this.enemies]) if (!a.alive){
        for (const el of a.segmentEls) if (el.parentNode) this.actorsEl.removeChild(el);
        a.segmentEls = [];
      }
      // spawn new food if eaten
      if (foodEatenBy) this.placeFoodRandom();
      // update visuals
      this.updateAllSegmentPositions();
      // win condition: 65% coverage
      const totalCells = this.GRID_COLS * this.GRID_ROWS;
      for (const p of this.players) if (p.alive && p.snake.length >= Math.ceil(0.65 * totalCells)){ this.endGame(true, p.id); return; }
      // handle aggro
      this.handleAggro(foodEatenBy);
      this.updateScoreUI();
    },

    handleAggro: function(foodEatenBy){
      const enemiesHaveEaten = this.enemies.some(e => e.eats > 0);
      const triggeringPlayer = this.players.find(p => p.consecutiveEats > 5);
      if (!this.aggroActive && triggeringPlayer && !enemiesHaveEaten){
        this.aggroActive = true; this.aggroTimer = 10000; this.aggroTriggerPlayerId = triggeringPlayer.id; this.aggroPlayerEatsAtStart = triggeringPlayer.eats;
        for (const e of this.enemies) e.aggro = true;
      }
      if (this.aggroActive){
        const trigger = this.players.find(p => p.id === this.aggroTriggerPlayerId);
        if (!trigger || (trigger.eats - this.aggroPlayerEatsAtStart) >= 2){ this.endAggro(); return; }
        if (this.aggroTimer <= 0){ this.endAggro(); return; }
      }
    },

    endAggro: function(){ this.aggroActive = false; this.aggroTimer = 0; this.aggroTriggerPlayerId = null; this.aggroPlayerEatsAtStart = 0; for (const e of this.enemies) e.aggro = false; },

    // -------------------------
    // Tick loop
    // -------------------------
    tick: function(){
      const now = performance.now();
      if (!this.lastTime) this.lastTime = now;
      const delta = now - this.lastTime;
      this.lastTime = now;
      if (this.running){
        this.moveTimer += delta;
        if (this.aggroActive) this.aggroTimer -= delta;
        if (this.moveTimer >= this.moveInterval){
          this.moveTimer = 0;
          this.updateTick();
        }
      }
      requestAnimationFrame(() => this.tick());
    },

    // -------------------------
    // UI helpers
    // -------------------------
    updateScoreUI: function(){
      const p1 = this.players[0] ? this.players[0].eats : 0;
      const p2 = this.players[1] ? this.players[1].eats : 0;
      this.scoreText.setAttribute('value', `Score P1: ${p1}   P2: ${p2}`);
    },

    showMessage: function(text){
      // small overlay using scene's message entity (we reuse UI title area by changing it)
      // For simplicity, use console and UI title color change
      if (!text) return;
      console.log('MSG:', text);
    },

    endGame: function(playerWon, winnerId){
      this.running = false;
      // unlock UI visuals
      this.startBtn.setAttribute('color','#111');
      this.stopBtn.setAttribute('color','#333');
      if (playerWon) this.showMessage(`Player ${winnerId} Wins!`);
      else {
        const alivePlayers = this.players.filter(p => p.alive).map(p => p.id);
        if (alivePlayers.length === 1) this.showMessage(`Player ${alivePlayers[0]} Survived — Game Over`);
        else this.showMessage('Game Over');
      }
    }
  });

  // attach game-manager to scene root
  document.querySelector('a-scene').setAttribute('game-manager', '');

  // -------------------------
  // Add UI classes to clickable elements
  // -------------------------
  // Mark UI boxes as clickable
  document.querySelectorAll('.clickable').forEach(el => el.classList.add('ui'));

  // -------------------------
  // Final notes:
  // - This implementation is intentionally modular and commented.
  // - You can tune AI weights, grid size, sphere radius, and visual parameters easily in the component code.
  // - All UI is inside the A-Frame scene and interactive via mouse cursor.
  // -------------------------
  </script>
</body>
</html>
